<?xml version="1.0" encoding="UTF-8"?>
<viewsettings>
    <scheme name="event_demo">
        <opengl antialiase="1" dither="0"/>
        <background backgroundColor="255,255,255" showGrid="0" gridXSize="100.00" gridYSize="100.00"/>
        <vehicles vehicleMode="0" vehicleQuality="2" minVehicleSize="4.00"
                  vehicleExaggeration="3.50" showBlinker="1"
                  vehicleName_show="0" vehicleName_size="50.00"
                  vehicleName_color="0,0,0">
            <colorScheme name="given vehicle/type color">
                <entry color="yellow"/>
            </colorScheme>
        </vehicles>
        <pois poiTextParam="PARAM_TEXT" poi_minSize="4.00" poi_exaggeration="1.50"
              poi_constantSize="1" poi_constantSizeSelected="1" poiDetail="16"
              poiName_show="0" poiName_size="100.00" poiName_color="0,0,0"
              poiName_bgColor="220,255,255,255" poiName_constantSize="1"
              poiName_onlySelected="0"
              poiType_show="0" poiType_size="80.00" poiType_color="0,0,0"
              poiType_bgColor="220,255,255,255" poiType_constantSize="1"
              poiType_onlySelected="0"
              poiText_show="0" poiText_size="100.00" poiText_color="0,0,0"
              poiText_bgColor="220,255,255,255" poiText_constantSize="1"
              poiText_onlySelected="0">
            <colorScheme name="given POI color">
                <entry color="red"/>
            </colorScheme>
            <colorScheme name="by selection">
                <entry color="179,179,179" name="unselected"/>
                <entry color="0,102,204" name="selected"/>
            </colorScheme>
            <colorScheme name="uniform">
                <entry color="red"/>
            </colorScheme>
        </pois>
        <polys poly_minSize="0.00" poly_exaggeration="1.00" poly_constantSize="0"
               polyName_show="0" polyName_size="50.00" polyName_color="255,0,128"
               polyName_constantSize="1" polyType_show="0" polyType_size="50.00"
               polyType_color="255,0,128" polyType_constantSize="1"/>
        <legend showSizeLegend="0"/>
    </scheme>
</viewsettings>
